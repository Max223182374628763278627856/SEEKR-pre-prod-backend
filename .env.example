# ╔══════════════════════════════════════════════════════════════╗
# ║  SEEKR pre-prod — Variables d'environnement                   ║
# ║  Copier ce fichier en .env et remplir les valeurs             ║
# ╚══════════════════════════════════════════════════════════════╝

# ── Core ───────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development
JWT_SECRET=CHANGER_MOI_ABSOLUMENT_32_CHARS_MIN
HASH_SALT=seekr_ip_salt_CHANGE_ME
SETUP_KEY=votre_cle_setup_admin

# ── MongoDB ────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://user:password@cluster.mongodb.net/seekr

# ── Crawl ──────────────────────────────────────────────────────
MAX_CRAWL_PAGES=80

# ── Stripe ─────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_STARTER=price_...
STRIPE_PRICE_PME=price_...
STRIPE_PRICE_AGENCY=price_...

# ── Cloudinary (white-label logos) ────────────────────────────
CLOUDINARY_CLOUD_NAME=votre_cloud
CLOUDINARY_API_KEY=votre_api_key
CLOUDINARY_API_SECRET=votre_api_secret

# ── Email (Resend) ─────────────────────────────────────────────
RESEND_API_KEY=re_...
SMTP_FROM=SEEKR <noreply@seekr-search.fr>

# ── URLs ───────────────────────────────────────────────────────
DASHBOARD_URL=https://app.seekr-search.fr

# ── SEEKR Agent IA (NEW pre-prod) ─────────────────────────────
# Clé API Anthropic pour l'agent conversationnel
ANTHROPIC_API_KEY=sk-ant-...

# Modèle LLM à utiliser
# Options : claude-haiku-4-5-20251001 (rapide/économique) | claude-sonnet-4-6 (meilleur)
SEEKR_LLM_MODEL=claude-haiku-4-5-20251001

# Tokens max par réponse agent (350 = ~250 mots)
SEEKR_AGENT_MAX_TOKENS=350

# Température créativité (0.3 = plus factuel, 0.7 = plus naturel)
SEEKR_AGENT_TEMPERATURE=0.4
